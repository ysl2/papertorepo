# Docker Compose default.
# For a host-side Python workflow, replace `db` with `127.0.0.1` or your own PostgreSQL host.
DATABASE_URL=postgresql+psycopg://papertorepo:papertorepo@db:5432/papertorepo
DATA_DIR=data
DEFAULT_CATEGORIES=cs.CV

GITHUB_TOKEN=
HUGGINGFACE_TOKEN=
ALPHAXIV_TOKEN=

SYNC_PAPERS_ARXIV_MIN_INTERVAL=3.0
SYNC_PAPERS_ARXIV_TTL_DAYS=30
SYNC_PAPERS_ARXIV_ID_BATCH_SIZE=100
SYNC_PAPERS_ARXIV_LIST_PAGE_SIZE=2000

FIND_REPOS_LINK_TTL_DAYS=7
FIND_REPOS_HUGGINGFACE_ENABLED=true
FIND_REPOS_ALPHAXIV_ENABLED=true
FIND_REPOS_HUGGINGFACE_MIN_INTERVAL=0.2
FIND_REPOS_ALPHAXIV_MIN_INTERVAL=0.2
FIND_REPOS_WORKER_CONCURRENCY=24
FIND_REPOS_HUGGINGFACE_MAX_CONCURRENT=4
FIND_REPOS_ALPHAXIV_MAX_CONCURRENT=4

REFRESH_METADATA_GITHUB_MIN_INTERVAL=0.2
REFRESH_METADATA_GITHUB_ANONYMOUS_MIN_INTERVAL=60.0
REFRESH_METADATA_GITHUB_GRAPHQL_BATCH_SIZE=50
REFRESH_METADATA_GITHUB_GRAPHQL_MAX_CONCURRENT=1
REFRESH_METADATA_GITHUB_REST_FALLBACK_MAX_CONCURRENT=2

# Frontend search box SQL mode: off, read_only, or read_write.
SQL_SEARCH_MODE=off

JOB_QUEUE_WORKER_POLL_SECONDS=1.0
JOB_QUEUE_RUNNING_TIMEOUT_SECONDS=1800

PUBLIC_EXPORT_DOWNLOADS=true
CORS_ORIGINS=*

# Frontend runtime config.
FRONTEND_ACTIVE_DASHBOARD_POLL_MS=1000
FRONTEND_IDLE_DASHBOARD_POLL_MS=8000
FRONTEND_ACTIVE_JOBS_POLL_MS=1000
FRONTEND_PASSIVE_JOBS_POLL_MS=5000
FRONTEND_TABLE_REFRESH_POLL_MS=20000
FRONTEND_PAPER_BATCH_SIZE=1000
FRONTEND_REPO_PREVIEW_LIMIT=10000
FRONTEND_JOB_PREVIEW_LIMIT=500
FRONTEND_DISPLAYED_KEYS_SYNC_THROTTLE_MS=200
FRONTEND_TOOLTIP_SHOW_DELAY_MS=200
FRONTEND_COPY_FEEDBACK_MS=500
FRONTEND_LAUNCH_FEEDBACK_MS=3000
